{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "g++",
            "args": [
                "Index.cpp",
                "LogInPage.cpp",
                "RegisterUser.cpp",
                "RegisterHospital.cpp",
                "UserLogIn.cpp",
                "UserMenu.cpp",
                "HospLogIn.cpp",
                "HospMenu.cpp",
                "-o",
                "Index.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ]
}
